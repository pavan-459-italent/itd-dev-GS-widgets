{
  "connectors": [
    {
      "name": "REST Countries",
      "url": "https://restcountries.com/v3.1/all",
      "method": "GET",
      "headers": [
        { "key": "Accept", "value": "application/json", "overridable": false }
      ],
      "query_parameters": [
        { "key": "fields", "value": "name,capital,population,flags,region", "overridable": false }
      ],
      "permalink": "rest-countries"
    },
    {
      "name": "Weather Forecast",
      "url": "https://api.open-meteo.com/v1/forecast",
      "method": "GET",
      "headers": [
        { "key": "Accept", "value": "application/json", "overridable": false }
      ],
      "query_parameters": [
        { "key": "latitude", "value": "52.52", "overridable": true },
        { "key": "longitude", "value": "13.41", "overridable": true },
        { "key": "daily", "value": "temperature_2m_max,temperature_2m_min,weathercode", "overridable": false },
        { "key": "timezone", "value": "auto", "overridable": false },
        { "key": "forecast_days", "value": "7", "overridable": true }
      ],
      "permalink": "weather-forecast"
    }
  ]
}
